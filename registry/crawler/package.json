{
  "name": "@openedx-design-system/crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ods-crawler": "./dist/index.js"
  },
  "scripts": {
    "preinstall": "node -e \"if(!(process.env.npm_config_user_agent||'').startsWith('pnpm/'))throw new Error('Use pnpm. See README.')\"",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --test --import tsx/esm ./test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "ingest:fixtures": "tsx src/index.ts ingest --from-fixtures"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "pnpm": ">=10.16.0"
  }
}
