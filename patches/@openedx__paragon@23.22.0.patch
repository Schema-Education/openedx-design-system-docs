@@ -30,15 +30,25 @@ class TransitionReplace extends React.Component {
   // 2. onChildEntering     (set the height to match the new content)
   // 3. onChildExited       (reset the height to null)
 
+  // React 19 / react-transition-group@4.4.5 compatibility: the upstream
+  // transition patch in this repo's `patches/` can hand off a null DOM
+  // node when a child unmounts mid-transition. The original handlers
+  // read `htmlNode.offsetHeight` to drive the height-swap animation and
+  // throw `TypeError: null is not an object` when the node is gone.
+  // Guard every onChildXxx handler so a null node no-ops on the
+  // animation side but still forwards the (null) signal to consumer
+  // callbacks for compatibility with the original API contract.
   onChildEnter(htmlNode) {
     if (this.props.onChildEnter) {
       this.props.onChildEnter(htmlNode);
     }
   }
   onChildEntering(htmlNode) {
-    this.setState({
-      height: htmlNode.offsetHeight
-    });
+    if (htmlNode != null) {
+      this.setState({
+        height: htmlNode.offsetHeight
+      });
+    }
     if (this.props.onChildEntering) {
       this.props.onChildEntering(htmlNode);
     }
@@ -52,9 +62,11 @@ class TransitionReplace extends React.Component {
     }
   }
   onChildExit(htmlNode) {
-    this.setState({
-      height: htmlNode.offsetHeight
-    });
+    if (htmlNode != null) {
+      this.setState({
+        height: htmlNode.offsetHeight
+      });
